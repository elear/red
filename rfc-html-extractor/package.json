{
  "name": "red-rfc-html-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "generate": "node --experimental-strip-types ./src/index.ts 1137",
    "format": "npx prettier --config ./prettier.config.cjs src --write",
    "test": "TZ=UTC npm run test:unittests && npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "test:unittests": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ietf-tools/red.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.842.0",
    "@napi-rs/canvas": "0.1.77",
    "@types/luxon": "3.4.2",
    "feed": "5.1.0",
    "jsdom": "26.1.0",
    "lodash-es": "4.17.21",
    "luxon": "3.5.0",
    "sanitize-html": "2.17.0",
    "sharp": "0.34.3",
    "unpdf": "1.2.2",
    "vue-tsc": "3.0.5",
    "zod": "3.25.30"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.0.10",
    "@types/sanitize-html": "2.16.0",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
