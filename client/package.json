{
  "name": "red",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "npm run generate && npm run build:nuxt",
    "build:nuxt": "npx --no nuxt build",
    "build:dev": "npm run build:nuxt:dev",
    "build:nuxt:dev": "npx --no nuxt prepare && npx --no nuxt build --envName development",
    "dev": "npm run generate && npm run dev:nuxt",
    "dev:nuxt": "nuxt dev",
    "cleanup": "nuxt cleanup",
    "preview": " npm run build:nuxt && nuxt preview",
    "preview:dev": " npm run build:nuxt:dev && nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "TZ=UTC npm run test:unittests && npm run test:types && npm run test:lint",
    "test:lint": "eslint .",
    "test:lint:fix": "eslint . --fix",
    "test:types": "nuxt prepare && vue-tsc -b --noEmit",
    "test:unittests": "vitest run",
    "test:unittests:watch": "vitest",
    "generate": "npm run generate:api-red",
    "generate:api-red": "npx --no apigen-ts http://localhost:8000/api/schema/ --inline-enums --parse-dates ./generated/red-client.ts"
  },
  "dependencies": {
    "@internationalized/date": "3.8.1",
    "@nuxt/content": "3.6.3",
    "@nuxt/eslint": "1.4.1",
    "@nuxt/fonts": "0.11.4",
    "@nuxt/icon": "1.13.0",
    "@nuxtjs/color-mode": "3.4.4",
    "@pinia/nuxt": "0.11.2",
    "@tailwindcss/vite": "4.1.11",
    "@vueuse/core": "13.1.0",
    "apigen-ts": "1.1.0",
    "better-sqlite3": "12.2.0",
    "core-js": "3.40.0",
    "feed": "4.2.2",
    "lodash-es": "4.17.21",
    "luxon": "3.5.0",
    "nitropack": "2.10.4",
    "nuxt": "4.0.3",
    "pinia-plugin-persistedstate": "4.4.1",
    "postcss-nested-import": "1.3.0",
    "reka-ui": "2.4.1",
    "remark-heading-id": "1.0.1",
    "sharp": "0.34.2",
    "simple-git": "3.27.0",
    "tailwindcss": "4.1.11",
    "typesense-instantsearch-adapter": "2.9.0",
    "vue": "3.5.13",
    "vue-instantsearch": "4.20.8"
  },
  "devDependencies": {
    "@babel/runtime": "7.27.1",
    "@nuxt/test-utils": "3.19.1",
    "@playwright/test": "1.49.1",
    "@types/lodash-es": "4.17.12",
    "@types/luxon": "3.4.2",
    "@types/remark-heading-id": "1.0.0",
    "@vue/test-utils": "2.4.6",
    "fast-xml-parser": "4.5.1",
    "happy-dom": "15.11.7",
    "playwright": "1.49.1",
    "playwright-core": "1.49.1",
    "vitest": "2.1.8",
    "vue-tsc": "3.0.5"
  },
  "peerDependencies": {
    "typescript": "5.9.2"
  }
}
