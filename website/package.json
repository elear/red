{
  "name": "red",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "npm run build:nuxt",
    "build:nuxt": "npx --no nuxt build",
    "build:dev": "npm run build:nuxt:dev",
    "build:nuxt:dev": "npx --no nuxt prepare && npx --no nuxt build --envName development",
    "dev": "npm run dev:nuxt",
    "dev:nuxt": "nuxt dev",
    "cleanup": "nuxt cleanup",
    "preview": "npm run build:nuxt && nuxt preview",
    "preview:dev": " npm run build:nuxt:dev && nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "TZ=UTC npm run test:unittests && npm run test:types && npm run test:lint",
    "test:lint": "eslint .",
    "test:lint:fix": "eslint . --fix",
    "test:types": "nuxt prepare && vue-tsc -b --noEmit",
    "test:unittests": "TZ=UTC vitest run",
    "test:unittests:watch": "TZ=UTC vitest",
    "generate:content-metadata": "node ./scripts/generate-content-metadata.ts"
  },
  "dependencies": {
    "@iconify-json/eos-icons": "1.2.4",
    "@iconify-json/f7": "1.2.2",
    "@iconify-json/fa-solid": "1.2.2",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/ph": "1.2.2",
    "@iconify-json/vaadin": "1.2.1",
    "@internationalized/date": "3.12.1",
    "@nuxt/content": "3.13.0",
    "@nuxt/icon": "2.2.2",
    "@nuxtjs/color-mode": "4.0.0",
    "@opentelemetry/auto-instrumentations-web": "0.53.0",
    "@opentelemetry/context-zone": "2.2.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.207.0",
    "@opentelemetry/instrumentation": "0.207.0",
    "@opentelemetry/resources": "2.2.0",
    "@opentelemetry/sdk-trace-web": "2.2.0",
    "@opentelemetry/semantic-conventions": "1.37.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/vite": "4.3.0",
    "@vueuse/core": "14.3.0",
    "better-sqlite3": "12.9.0",
    "commander": "14.0.3",
    "core-js": "3.49.0",
    "es-toolkit": "1.46.1",
    "luxon": "3.7.2",
    "nitropack": "2.13.4",
    "nuxt": "4.4.5",
    "nuxt-vitalizer": "2.0.0",
    "pinia-plugin-persistedstate": "4.7.1",
    "postcss-nested-import": "1.3.0",
    "reka-ui": "2.9.7",
    "remark-heading-id": "1.0.1",
    "simple-git": "3.36.0",
    "tailwindcss": "4.3.0",
    "typesense-instantsearch-adapter": "3.0.2",
    "vue": "3.5.34",
    "vue-instantsearch": "4.26.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/runtime": "7.29.2",
