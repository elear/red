    "@iconify-json/ic": "1.2.4",
    "@iconify-json/vscode-icons": "1.2.35",
    "@nuxt/eslint": "1.9.0",
    "@nuxt/test-utils": "3.20.1",
    "@playwright/test": "1.56.1",
    "@types/luxon": "3.7.1",
    "@types/remark-heading-id": "1.0.0",
    "@vue/test-utils": "2.4.6",
    "fast-xml-parser": "5.7.1",
    "happy-dom": "20.0.8",
    "playwright": "1.56.1",
