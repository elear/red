{
  "name": "precomputer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "format": "npx prettier --config ./prettier.config.cjs src --write",
    "test": "TZ=UTC npm run test:unittests && npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "test:unittests": "TZ=UTC vitest run",
    "test:unittests:watch": "TZ=UTC vitest run --watch",
    "generate:test-data": "node ./src/utilities/rfcs-test-data-regenerate.ts",
    "generate:api": "npx --no apigen-ts http://localhost:8000/api/schema/ --inline-enums --parse-dates ./generated/api-client.ts",
    "dev-api-server": "node ./src/utilities/dev-api-server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ietf-tools/red.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.987.0",
    "@aws-sdk/core": "3.973.7",
    "@napi-rs/canvas": "0.1.77",
    "@supercharge/promise-pool": "3.2.0",
    "@types/luxon": "3.4.2",
    "apigen-ts": "1.3.0",
    "es-toolkit": "1.44.0",
    "feed": "5.1.0",
    "jsdom": "26.1.0",
    "libxml2-wasm": "0.6.0",
    "luxon": "3.5.0",
    "sanitize-html": "2.17.0",
    "satori": "0.26.0",
    "satori-html": "0.3.2",
    "sharp": "0.34.3",
    "sitemap": "9.0.1",
    "unpdf": "1.4.0",
    "vue": "3.5.31",
    "vue-tsc": "3.0.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/node": "24.0.10",
    "@types/sanitize-html": "2.16.0",
    "fastify": "5.7.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
