{
  "name": "rfced-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy --env staging",
    "dev": "wrangler dev --env staging",
    "dev-remote": "wrangler dev --env staging --remote",
    "cf-typegen": "wrangler types --env staging",
    "test": "npm run test:unittests && npm run test:types",
    "test:unittests": "TZ=UTC vitest run",
    "test:unittests:watch": "TZ=UTC vitest",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "cookie": "1.0.2",
    "itty-router": "5.0.22",
    "luxon": "3.7.2",
    "rfc4648": "1.5.4",
    "typescript": "5.5.2",
    "vitest": "4.1.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.3",
    "@types/luxon": "3.7.1",
    "@types/node": "25.7.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "wrangler": "4.43.0"
  }
}
